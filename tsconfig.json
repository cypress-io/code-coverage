{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "types": ["node", "cypress"]
  },
  "include": [
    "lib/**/*",
    "middleware/**/*",
    "test/**/*",
    "vitest.config.ts"
  ],
  "exclude": [
    "test-apps/**/*",
    "node_modules",
    "dist",
    "coverage"
  ]
}

